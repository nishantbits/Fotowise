.git/
.gitignore

# Editor
.vscode/
.idea/
*.swp

# OS
.DS_Store
Thumbs.db

# Logs
logs/
*.log

# Tests
coverage/
playwright-report/
test-results/

# Docs (not needed in image)
docs/
*.md
!README.md
