# ─────────────────────────────────────────────────────────────
# Fotowise Configuration (Public Template)
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────────

# Port the app runs on (default: 3000)
PORT=3000

# Node environment (development | production)
NODE_ENV=production

# Path to SQLite database file
# For Docker: /app/data/fotowise.db
# For Local: ./data/fotowise.db
DB_PATH=/app/data/fotowise.db

# Path to your photo library
# For Docker: /app/library
# For Local: C:\Users\Name\Pictures
LIBRARY_PATH=/app/library

# URL for the CLIP AI service (container name if using Docker)
CLIP_SERVICE_URL=http://clip-service:8001

# ─────────────────────────────────────────────────────────────
# Frontend (Vite)
# ─────────────────────────────────────────────────────────────

# Base URL for the API (change if running on a different port/host)
VITE_API_URL=http://localhost:3000/api

# ─────────────────────────────────────────────────────────────
# Optional: External AI Provider Keys
# ─────────────────────────────────────────────────────────────

# Add your OpenAI key here if you want to use cloud-based GPT features
OPENAI_API_KEY=your_openai_api_key_here
